# Environment example for nodejs-learning
# Use this file as a template and copy to .env

# App
NODE_ENV=dev
DEV_APP_PORT=3000
PRO_APP_PORT=3000

# MongoDB
# Local MongoDB (uncomment to use local):
# MONGO_URI_DEV=mongodb://localhost:27017/dbDev
# MONGO_URI_PRO=mongodb://localhost:27017/dbPro

# MongoDB Atlas example (replace <user>, <pass>, <cluster>, <dbname>):
# MONGO_URI_DEV=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# MONGO_URI_PRO=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# DB names (optional)
DEV_DB_NAME=dbDev
PRO_DB_NAME=dbPro
